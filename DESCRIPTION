Package: ERsim
Type: Package
Title: Emergency Room Queue Simulation
Version: 0.1.0
Authors@R: c(
    person("Mevin", "Biju", role = c("aut"), comment = "486097"),
    person("David", "Abraham", role = c("aut", "cre"), email = "david@example.com", comment = "487868"),
